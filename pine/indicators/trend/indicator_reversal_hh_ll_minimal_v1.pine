//@version=6
indicator("Reversal HH LL Minimal v1", shorttitle="Rev HH/LL v1", overlay=true, max_labels_count=200)

// Name: Reversal HH LL Minimal v1
// Type: Indicator
// Version: v1
// Description: Minimal reversal indicator focused on Higher High and Lower Low confirmed reversal signals.

leftBars = input.int(5, "Left Pivot Bars", minval=1)
rightBars = input.int(5, "Right Pivot Bars", minval=1)
atrLength = input.int(14, "ATR Length", minval=1)
minSwingAtrMult = input.float(0.75, "Min Swing Distance (ATR)", minval=0.0, step=0.05)
showHHLLLabels = input.bool(false, "Show HH / LL Labels")
showReversalSignals = input.bool(true, "Show Reversal Signals")
showTrendBackground = input.bool(true, "Show Trend Background")
useWickExtremes = input.bool(true, "Use Wick Extremes")

highSource = useWickExtremes ? high : math.max(open, close)
lowSource = useWickExtremes ? low : math.min(open, close)
atrValue = ta.atr(atrLength)
pivotHigh = ta.pivothigh(highSource, leftBars, rightBars)
pivotLow = ta.pivotlow(lowSource, leftBars, rightBars)
confirmedPivotBar = bar_index - rightBars
pivotAtr = atrValue[rightBars]

var float previousHigh = na
var float latestHigh = na
var int latestHighBar = na
var float previousLow = na
var float latestLow = na
var int latestLowBar = na
var int trendBias = 0  // 1 bullish, -1 bearish, 0 neutral

isHH = false
isLL = false
bullishReversal = false
bearishReversal = false

if not na(pivotHigh)
    highDistanceOk = na(latestHigh) or math.abs(pivotHigh - latestHigh) >= nz(pivotAtr, atrValue) * minSwingAtrMult

    if highDistanceOk
        previousHigh := latestHigh
        latestHigh := pivotHigh
        latestHighBar := confirmedPivotBar
        isHH := not na(previousHigh) and latestHigh > previousHigh

        if isHH and trendBias == -1
            bullishReversal := true

        if isHH
            trendBias := 1

        if showHHLLLabels and isHH
            label.new(latestHighBar, latestHigh, "HH", style=label.style_label_down, textcolor=color.white, color=color.new(color.lime, 0), size=size.small)

if not na(pivotLow)
    lowDistanceOk = na(latestLow) or math.abs(pivotLow - latestLow) >= nz(pivotAtr, atrValue) * minSwingAtrMult

    if lowDistanceOk
        previousLow := latestLow
        latestLow := pivotLow
        latestLowBar := confirmedPivotBar
        isLL := not na(previousLow) and latestLow < previousLow

        if isLL and trendBias == 1
            bearishReversal := true

        if isLL
            trendBias := -1

        if showHHLLLabels and isLL
            label.new(latestLowBar, latestLow, "LL", style=label.style_label_up, textcolor=color.white, color=color.new(color.red, 0), size=size.small)

plotshape(showReversalSignals and bullishReversal, title="Bullish Reversal", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.large, text="REV↑")
plotshape(showReversalSignals and bearishReversal, title="Bearish Reversal", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.large, text="REV↓")

bgcolor(showTrendBackground ? trendBias == 1 ? color.new(color.lime, 94) : trendBias == -1 ? color.new(color.red, 94) : na : na, title="Trend Background")

alertcondition(bullishReversal, title="Bullish Reversal Confirmed", message="Bullish reversal confirmed by Higher High")
alertcondition(bearishReversal, title="Bearish Reversal Confirmed", message="Bearish reversal confirmed by Lower Low")
