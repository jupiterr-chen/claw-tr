//@version=6
indicator("Market Structure Full v1", shorttitle="MS Full v1", overlay=true, max_lines_count=500, max_labels_count=500)

// Name: Market Structure Full v1
// Type: Indicator
// Version: v1
// Description: Confirmed market structure indicator with HH, HL, LH, LL, BOS, CHoCH and trend state.

leftBars = input.int(3, "Left Pivot Bars", minval=1)
rightBars = input.int(3, "Right Pivot Bars", minval=1)
useWickExtremes = input.bool(true, "Use Wick Extremes")
showPivotLabels = input.bool(true, "Show Structure Labels")
showSwingLines = input.bool(true, "Show Swing Connector Lines")
showBreakLabels = input.bool(true, "Show BOS / CHoCH Labels")
showBreakLevels = input.bool(true, "Show Active Break Levels")
showTrendBg = input.bool(true, "Show Trend Background")

highSource = useWickExtremes ? high : math.max(open, close)
lowSource = useWickExtremes ? low : math.min(open, close)

pivotHigh = ta.pivothigh(highSource, leftBars, rightBars)
pivotLow = ta.pivotlow(lowSource, leftBars, rightBars)
confirmedPivotBar = bar_index - rightBars

var float previousHigh = na
var float latestHigh = na
var int previousHighBar = na
var int latestHighBar = na
var string latestHighType = ""

var float previousLow = na
var float latestLow = na
var int previousLowBar = na
var int latestLowBar = na
var string latestLowType = ""

var float activeBullBreakLevel = na
var float activeBearBreakLevel = na
var int activeBullBreakBar = na
var int activeBearBreakBar = na
var bool bullLevelBroken = false
var bool bearLevelBroken = false

var int trendState = 0

isHH = false
isLH = false
isHL = false
isLL = false
bullishBreak = false
bearishBreak = false
bullishEventText = ""
bearishEventText = ""

if not na(pivotHigh)
    previousHigh := latestHigh
    previousHighBar := latestHighBar
    latestHigh := pivotHigh
    latestHighBar := confirmedPivotBar

    isHH := not na(previousHigh) and latestHigh > previousHigh
    isLH := not na(previousHigh) and latestHigh <= previousHigh
    latestHighType := na(previousHigh) ? "PH" : isHH ? "HH" : "LH"

    activeBullBreakLevel := latestHigh
    activeBullBreakBar := latestHighBar
    bullLevelBroken := false

    if showPivotLabels
        labelColorHigh = latestHighType == "HH" ? color.new(color.lime, 0) : latestHighType == "LH" ? color.new(color.orange, 0) : color.new(color.blue, 25)
        label.new(latestHighBar, latestHigh, latestHighType, style=label.style_label_down, textcolor=color.white, color=labelColorHigh, size=size.small)

    if showSwingLines and not na(previousHigh) and not na(previousHighBar)
        highLineColor = isHH ? color.new(color.lime, 0) : color.new(color.orange, 0)
        line.new(previousHighBar, previousHigh, latestHighBar, latestHigh, color=highLineColor, width=2)

if not na(pivotLow)
    previousLow := latestLow
    previousLowBar := latestLowBar
    latestLow := pivotLow
    latestLowBar := confirmedPivotBar

    isLL := not na(previousLow) and latestLow < previousLow
    isHL := not na(previousLow) and latestLow >= previousLow
    latestLowType := na(previousLow) ? "PL" : isLL ? "LL" : "HL"

    activeBearBreakLevel := latestLow
    activeBearBreakBar := latestLowBar
    bearLevelBroken := false

    if showPivotLabels
        labelColorLow = latestLowType == "LL" ? color.new(color.red, 0) : latestLowType == "HL" ? color.new(color.aqua, 0) : color.new(color.purple, 25)
        label.new(latestLowBar, latestLow, latestLowType, style=label.style_label_up, textcolor=color.white, color=labelColorLow, size=size.small)

    if showSwingLines and not na(previousLow) and not na(previousLowBar)
        lowLineColor = isLL ? color.new(color.red, 0) : color.new(color.aqua, 0)
        line.new(previousLowBar, previousLow, latestLowBar, latestLow, color=lowLineColor, width=2)

if not na(activeBullBreakLevel) and not bullLevelBroken and close > activeBullBreakLevel and close[1] <= activeBullBreakLevel
    bullishBreak := true
    bullishEventText := trendState == -1 ? "CHoCH↑" : "BOS↑"
    bullLevelBroken := true
    trendState := 1

if not na(activeBearBreakLevel) and not bearLevelBroken and close < activeBearBreakLevel and close[1] >= activeBearBreakLevel
    bearishBreak := true
    bearishEventText := trendState == 1 ? "CHoCH↓" : "BOS↓"
    bearLevelBroken := true
    trendState := -1

if showBreakLabels and bullishBreak
    label.new(bar_index, high, bullishEventText, style=label.style_label_up, textcolor=color.white, color=color.new(color.lime, 0), size=size.small)

if showBreakLabels and bearishBreak
    label.new(bar_index, low, bearishEventText, style=label.style_label_down, textcolor=color.white, color=color.new(color.red, 0), size=size.small)

plot(showBreakLevels ? activeBullBreakLevel : na, title="Active Bull Break Level", color=color.new(color.lime, 55), linewidth=2, style=plot.style_linebr)
plot(showBreakLevels ? activeBearBreakLevel : na, title="Active Bear Break Level", color=color.new(color.red, 55), linewidth=2, style=plot.style_linebr)

bgcolor(showTrendBg ? trendState == 1 ? color.new(color.lime, 94) : trendState == -1 ? color.new(color.red, 94) : na : na, title="Trend Background")

alertcondition(isHH, title="Higher High Confirmed", message="Confirmed Higher High")
alertcondition(isHL, title="Higher Low Confirmed", message="Confirmed Higher Low")
alertcondition(isLH, title="Lower High Confirmed", message="Confirmed Lower High")
alertcondition(isLL, title="Lower Low Confirmed", message="Confirmed Lower Low")
alertcondition(bullishBreak, title="Bullish BOS or CHoCH", message="Bullish structure break detected")
alertcondition(bearishBreak, title="Bearish BOS or CHoCH", message="Bearish structure break detected")
