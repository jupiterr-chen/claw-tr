//@version=6
strategy("Reversal HH LL Assist Strategy v1", shorttitle="Rev HH/LL Strat v1", overlay=true, pyramiding=0, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.05)

// Name: Reversal HH LL Assist Strategy v1
// Type: Strategy
// Version: v1
// Description: Strategy version of the HH/LL reversal assistant. Enters on confirmed reversal, uses structure invalidation as stop, and fixed RR / opposite signal as exits.

leftBars = input.int(5, "Left Pivot Bars", minval=1)
rightBars = input.int(5, "Right Pivot Bars", minval=1)
atrLength = input.int(14, "ATR Length", minval=1)
minSwingAtrMult = input.float(0.75, "Min Swing Distance (ATR)", minval=0.0, step=0.05)
riskReward = input.float(2.0, "Take Profit R Multiple", minval=0.5, step=0.25)
allowLong = input.bool(true, "Enable Long Trades")
allowShort = input.bool(true, "Enable Short Trades")
useOppositeSignalExit = input.bool(true, "Close On Opposite Reversal")
useWickExtremes = input.bool(true, "Use Wick Extremes")
showHHLLLabels = input.bool(true, "Show HH / LL Labels")
showReversalSignals = input.bool(true, "Show R↑ / R↓ Signals")
showInvalidationLevels = input.bool(true, "Show Invalidation Guide Lines")

highSource = useWickExtremes ? high : math.max(open, close)
lowSource = useWickExtremes ? low : math.min(open, close)
atrValue = ta.atr(atrLength)
pivotHigh = ta.pivothigh(highSource, leftBars, rightBars)
pivotLow = ta.pivotlow(lowSource, leftBars, rightBars)
confirmedPivotBar = bar_index - rightBars
pivotAtr = atrValue[rightBars]

var float previousHigh = na
var float latestHigh = na
var int latestHighBar = na
var float previousLow = na
var float latestLow = na
var int latestLowBar = na
var int trendBias = 0

var float bullInvalidationLevel = na
var float bearInvalidationLevel = na
var line bullInvalidationLine = na
var line bearInvalidationLine = na

var float activeLongStop = na
var float activeShortStop = na

isHH = false
isLL = false
bullishReversal = false
bearishReversal = false

if not na(pivotHigh)
    highDistanceOk = na(latestHigh) or math.abs(pivotHigh - latestHigh) >= nz(pivotAtr, atrValue) * minSwingAtrMult

    if highDistanceOk
        previousHigh := latestHigh
        latestHigh := pivotHigh
        latestHighBar := confirmedPivotBar
        isHH := not na(previousHigh) and latestHigh > previousHigh

        if showHHLLLabels and isHH
            label.new(latestHighBar, latestHigh, "HH", style=label.style_label_down, textcolor=color.white, color=color.new(color.lime, 0), size=size.tiny)

        if isHH and trendBias == -1
            bullishReversal := true
            bullInvalidationLevel := latestLow
            activeLongStop := latestLow

            if showInvalidationLevels and not na(latestLow)
                if not na(bullInvalidationLine)
                    line.delete(bullInvalidationLine)
                bullInvalidationLine := line.new(latestLowBar, latestLow, bar_index, latestLow, extend=extend.right, color=color.new(color.lime, 45), width=1, style=line.style_dashed)

        if isHH
            trendBias := 1

if not na(pivotLow)
    lowDistanceOk = na(latestLow) or math.abs(pivotLow - latestLow) >= nz(pivotAtr, atrValue) * minSwingAtrMult

    if lowDistanceOk
        previousLow := latestLow
        latestLow := pivotLow
        latestLowBar := confirmedPivotBar
        isLL := not na(previousLow) and latestLow < previousLow

        if showHHLLLabels and isLL
            label.new(latestLowBar, latestLow, "LL", style=label.style_label_up, textcolor=color.white, color=color.new(color.red, 0), size=size.tiny)

        if isLL and trendBias == 1
            bearishReversal := true
            bearInvalidationLevel := latestHigh
            activeShortStop := latestHigh

            if showInvalidationLevels and not na(latestHigh)
                if not na(bearInvalidationLine)
                    line.delete(bearInvalidationLine)
                bearInvalidationLine := line.new(latestHighBar, latestHigh, bar_index, latestHigh, extend=extend.right, color=color.new(color.red, 45), width=1, style=line.style_dashed)

        if isLL
            trendBias := -1

if allowLong and bullishReversal and not na(activeLongStop)
    if strategy.position_size < 0 and useOppositeSignalExit
        strategy.close("Short", comment="Opposite Reversal")
    strategy.entry("Long", strategy.long, comment="R↑")

if allowShort and bearishReversal and not na(activeShortStop)
    if strategy.position_size > 0 and useOppositeSignalExit
        strategy.close("Long", comment="Opposite Reversal")
    strategy.entry("Short", strategy.short, comment="R↓")

if strategy.position_size > 0 and not na(activeLongStop)
    longRisk = strategy.position_avg_price - activeLongStop
    longTarget = longRisk > 0 ? strategy.position_avg_price + longRisk * riskReward : na
    strategy.exit("Long Exit", from_entry="Long", stop=activeLongStop, limit=longTarget)

if strategy.position_size < 0 and not na(activeShortStop)
    shortRisk = activeShortStop - strategy.position_avg_price
    shortTarget = shortRisk > 0 ? strategy.position_avg_price - shortRisk * riskReward : na
    strategy.exit("Short Exit", from_entry="Short", stop=activeShortStop, limit=shortTarget)

plotshape(showReversalSignals and bullishReversal, title="Bullish Reversal", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="R↑", textcolor=color.white)
plotshape(showReversalSignals and bearishReversal, title="Bearish Reversal", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="R↓", textcolor=color.white)

alertcondition(bullishReversal, title="Bullish Reversal Confirmed", message="Bullish reversal confirmed by Higher High")
alertcondition(bearishReversal, title="Bearish Reversal Confirmed", message="Bearish reversal confirmed by Lower Low")
