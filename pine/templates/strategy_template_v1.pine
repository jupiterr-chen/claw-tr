//@version=5
strategy("Strategy Template v1", overlay=true, initial_capital=100000)

// Name: Strategy Template v1
// Type: Strategy
// Version: v1
// Description: Base template for new TradingView strategies.

inputFastLength = input.int(20, "Fast Length", minval=1)
inputSlowLength = input.int(50, "Slow Length", minval=1)

emaFast = ta.ema(close, inputFastLength)
emaSlow = ta.ema(close, inputSlowLength)

isLongSignal = ta.crossover(emaFast, emaSlow)
isExitSignal = ta.crossunder(emaFast, emaSlow)

if isLongSignal
    strategy.entry("Long", strategy.long)

if isExitSignal
    strategy.close("Long")

plot(emaFast, title="EMA Fast", color=color.new(color.green, 0))
plot(emaSlow, title="EMA Slow", color=color.new(color.red, 0))
