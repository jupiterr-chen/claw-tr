//@version=5
indicator("Indicator Template v1", overlay=true)

// Name: Indicator Template v1
// Type: Indicator
// Version: v1
// Description: Base template for new TradingView indicators.

inputSource = input.source(close, "Source")
inputLength = input.int(20, "Length", minval=1)

maValue = ta.ema(inputSource, inputLength)

plot(maValue, title="EMA", color=color.new(color.blue, 0), linewidth=2)
